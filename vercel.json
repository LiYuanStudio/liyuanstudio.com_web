{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": false
  },
  "framework": "vite",
  "installCommand": "npm install && npm run build:api",
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 10,
      "includeFiles": "server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/login/", "destination": "/login/index.html" },
    { "source": "/register/", "destination": "/register/index.html" },
    { "source": "/forgot-password/", "destination": "/forgot-password/index.html" },
    { "source": "/reset-password/", "destination": "/reset-password/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/profile/", "destination": "/profile/index.html" },
    { "source": "/products/papyrusdesktop/", "destination": "/products/papyrusdesktop/index.html" },
    { "source": "/blog/", "destination": "/blog/index.html" },
    { "source": "/blog/release/", "destination": "/blog/index.html" },
    { "source": "/news/", "destination": "/news/index.html" },
    { "source": "/news/:slug/", "destination": "/news/index.html" },
    { "source": "/news/:slug", "destination": "/news/index.html" },
    { "source": "/~/", "destination": "/profile/" },
    { "source": "/~/:username/:blogNumber([0-9]+)/", "destination": "/profile/" },
    { "source": "/~/:username/:blogNumber([0-9]+)", "destination": "/profile/" },
    { "source": "/~/:username/", "destination": "/profile/" },
    { "source": "/~/:username", "destination": "/profile/" },
    { "source": "/:username/:blogNumber([0-9]+)/", "destination": "/profile/" },
    { "source": "/:username/:blogNumber([0-9]+)", "destination": "/profile/" },
    { "source": "/:username/", "destination": "/profile/" },
    { "source": "/:username", "destination": "/profile/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    }
  ]
}
