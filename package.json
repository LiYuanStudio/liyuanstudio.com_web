{
  "name": "liyuanstudio-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "server"
  ],
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:web": "vite",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "test": "vitest run --config=vitest.config.ts && vitest run --config=server/vitest.config.ts",
    "test:web": "vitest run --config=vitest.config.ts",
    "test:api": "vitest run --config=server/vitest.config.ts",
    "coverage": "vitest run --coverage --config=vitest.config.ts && vitest run --coverage --config=server/vitest.config.ts",
    "coverage:web": "vitest run --coverage --config=vitest.config.ts",
    "coverage:api": "vitest run --coverage --config=server/vitest.config.ts",
    "dev:api": "npm run dev --workspace=server",
    "build:api": "npm run build --workspace=server",
    "start:api": "npm run start --workspace=server",
    "seed:api": "npm run seed --workspace=server",
    "promote-admins:api": "npm run promote-admins --workspace=server",
    "check:secrets": "tsx scripts/check-secrets.ts",
    "guard:clean-deploy": "tsx scripts/guard-clean-deploy.ts",
    "deploy:vercel:prod": "npm run guard:clean-deploy && npm run build:api && npm run build && npx vercel deploy --prod --yes"
  },
  "dependencies": {
    "@arco-design/web-react": "^2.66.15",
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.27",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-easy-crop": "^6.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "jsdom": "^26.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.6",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
