{
  "name": "liyuanstudio-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "server"
  ],
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:web": "vite",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "dev:api": "npm run dev --workspace=server",
    "build:api": "npm run build --workspace=server",
    "start:api": "npm run start --workspace=server",
    "seed:api": "npm run seed --workspace=server",
    "check:secrets": "tsx scripts/check-secrets.ts"
  },
  "dependencies": {
    "@arco-design/web-react": "^2.66.15",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
