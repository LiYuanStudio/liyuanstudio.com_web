{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "liyuanstudiocom",
  "pages_build_output_dir": "dist",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "vars": {
    "API_UPSTREAM_ORIGIN": "https://liyuanstudio-com-web.vercel.app"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
